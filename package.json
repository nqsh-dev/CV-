{
  "name": "cvplus",
  "version": "3.0.0",
  "description": "CV+ — Générateur de CV Professionnel",
  "main": "main.js",
  "scripts": {
    "start":        "electron .",
    "dev":          "electron . --dev",
    "build":        "electron-builder",
    "start-server": "node backend/server.js"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron":         "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId":       "cm.cvplus.app",
    "productName": "CV+",
    "files": [
      "**/*",
      "!node_modules/**/.bin",
      "!**/*.map"
    ],
    "extraResources": [{ "from": ".env", "to": ".env" }],
    "win":   { "target": "nsis",     "icon": "assets/logo.png" },
    "mac":   { "target": "dmg",      "icon": "assets/logo.png" },
    "linux": { "target": "AppImage", "icon": "assets/logo.png" }
  }
}
