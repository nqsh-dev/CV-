{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/payment/initiate", "dest": "/api/payment/initiate.js" },
    { "src": "/api/payment/refund", "dest": "/api/payment/refund.js" },
    { "src": "/api/payment/status/(.*)", "dest": "/api/payment/status/[transactionId].js" }
  ]
}
